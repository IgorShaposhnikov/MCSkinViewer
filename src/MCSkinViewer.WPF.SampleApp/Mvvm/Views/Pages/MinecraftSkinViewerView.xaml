<UserControl
    x:Class="MCSkinViewer.WPF.SampleApp.Mvvm.Views.Pages.MinecraftSkinViewerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:MCSkinViewer.WPF;assembly=MCSkinViewer.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MCSkinViewer.WPF.SampleApp.Mvvm.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodels="clr-namespace:MCSkinViewer.WPF.SampleApp.Mvvm.ViewModels"
    Width="800"
    Height="600"
    d:DataContext="{d:DesignInstance Type=viewmodels:MinecraftSkinViewerViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <controls:SkinViewer x:Name="SkinControl" SkinPath="{Binding SkinPath}" />
    </Grid>
</UserControl>
