<UserControl
    x:Class="MCSkinViewer.WPF.SkinViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:MCSkinViewer.WPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  3D Viewport  -->
        <Viewport3D
            x:Name="viewport"
            Grid.Row="0"
            MouseLeftButtonDown="Viewport_MouseLeftButtonDown"
            MouseMove="Viewport_MouseMove"
            MouseWheel="Viewport_MouseWheel"
            RenderOptions.BitmapScalingMode="NearestNeighbor"
            SizeChanged="Viewport_SizeChanged">

            <!--  Камера  -->
            <Viewport3D.Camera>
                <PerspectiveCamera
                    x:Name="camera"
                    FieldOfView="45"
                    LookDirection="0,0,-1"
                    Position="0,0,5"
                    UpDirection="0,1,0" />
            </Viewport3D.Camera>

            <!--  Освещение  -->
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <Model3DGroup>
                        <!--  Основной глобальный свет (дает 80% яркости без теней и бликов)  -->
                        <AmbientLight Color="#CCCCCC" />

                        <!--  Легкое затенение граней сверху вниз  -->
                        <DirectionalLight Direction="0,-1,-0.5" Color="#444444" />

                        <!--  Очень слабое боковое затенение для объема  -->
                        <DirectionalLight Direction="-1,0,0" Color="#222222" />

                    </Model3DGroup>
                </ModelVisual3D.Content>
            </ModelVisual3D>

            <!--  Модель игрока  -->
            <ModelVisual3D x:Name="playerModel" />
        </Viewport3D>

        <!--  Панель управления  -->
        <StackPanel
            Grid.Row="1"
            Margin="0"
            Background="#16213e"
            Orientation="Vertical">

            <StackPanel
                Margin="10,8"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Margin="5,0"
                    Padding="12,6"
                    Background="#0f3460"
                    BorderBrush="#e94560"
                    Click="LoadSkin_Click"
                    Content="📂 Загрузить скин"
                    Cursor="Hand"
                    FontSize="13"
                    Foreground="White" />
                <Button
                    x:Name="btnAutoRotate"
                    Margin="5,0"
                    Padding="12,6"
                    Background="#0f3460"
                    BorderBrush="#0f3460"
                    Click="AutoRotate_Click"
                    Content="🔄 Авто-вращение"
                    Cursor="Hand"
                    FontSize="13"
                    Foreground="White" />
                <Button
                    Margin="5,0"
                    Padding="12,6"
                    Background="#0f3460"
                    BorderBrush="#0f3460"
                    Click="ResetView_Click"
                    Content="⟳ Сбросить вид"
                    Cursor="Hand"
                    FontSize="13"
                    Foreground="White" />
            </StackPanel>

            <TextBlock
                x:Name="statusText"
                Margin="0,0,0,8"
                HorizontalAlignment="Center"
                FontSize="11"
                Foreground="#aaaaaa"
                Text="Перетащите PNG-файл скина или нажмите 'Загрузить скин'" />
        </StackPanel>
    </Grid>
</UserControl>
